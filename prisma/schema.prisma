// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Audit Log (Admin Monitoring — tracks all user activity) ──────────────────
model AuditLog {
  id          String   @id @default(cuid())
  userId      String?  // null = unauthenticated attempt
  userEmail   String?  // snapshot of email at time of action
  userName    String?
  userRole    String?
  action      String   // LOGIN, LOGOUT, LOGIN_FAILED, CREATE, UPDATE, DELETE, VIEW, etc.
  entity      String   // product, order, user, category, company_info, etc.
  entityId    String?  // ID of the affected entity
  description String   // human-readable description
  ipAddress   String?
  userAgent   String?  // browser/device info
  statusCode  Int?     // HTTP status code (for API calls)
  method      String?  // GET, POST, PUT, DELETE
  path        String?  // API path
  createdAt   DateTime @default(now())
}

// ─── Authentication & Roles ──────────────────────────────────────────────────
// Role hierarchy: ADMIN > MANAGER > CASHIER
//   - ADMIN:   full access (users, products, orders, inventory, dashboard, settings)
//   - MANAGER: products, orders, inventory, dashboard (no user management)
//   - CASHIER: POS terminal + own order history only

// ─── Company Info (editable business information shown on receipts) ──────────
// A single row (id = "default") stores the business information.
// The admin edits this via the Settings page; changes appear on all new receipts.

model CompanyInfo {
  id              String   @id @default("default")
  name            String   @default("VeeSkin Essentials")
  tagline         String   @default("Skincare & Perfume Boutique")
  address         String   @default("Osu, Oxford Street, Accra, Ghana")
  phone           String   @default("+233 24 123 4567")
  whatsapp        String   @default("+233 24 123 4567")
  email           String   @default("hello@veeskin.com")
  website         String?
  tin             String?  // Tax Identification Number
  logoUrl         String?  // URL to logo image (shown on receipt header)
  footerMessage   String   @default("Thank you for shopping with us!")
  refundPolicy    String   @default("Goods sold are not returnable.")
  // Tax rates (Ghana defaults — editable)
  nhilRate        Float    @default(0.025)  // 2.5%
  getfundRate     Float    @default(0.025)  // 2.5%
  vatRate         Float    @default(0.10)   // 10%
  // Metadata
  updatedAt       DateTime @updatedAt
  updatedById     String?
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  passwordHash    String
  role            String    @default("CASHIER") // ADMIN | MANAGER | CASHIER
  // Per-user permission overrides (JSON). Keys are Permission names, values are true/false.
  // Absent keys fall back to the role default from PERMISSIONS in auth-types.ts.
  // Example: {"viewDashboard": true, "productDelete": false}
  permissionsJson String?
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  orders          Order[]   @relation("OrderCashier")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  icon      String?
  color     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id          String      @id @default(cuid())
  name        String
  sku         String      @unique
  description String?
  // Product attributes used for auto-SKU generation
  brand       String?
  size        String?
  color       String?
  price       Float
  cost        Float       @default(0)
  // ─── Inventory management fields ───
  stock       Int         @default(0)  // Current Quantity (on hand)
  openingStock Int        @default(0)  // Opening Stock (initial quantity at start of period)
  lowStock    Int         @default(10) // Minimum Stock Level (alert threshold)
  reorderPoint Int        @default(20) // Reorder Point (when to place a new order)
  maxStock    Int         @default(100) // Maximum Stock Level (upper limit)
  batchNumber String?
  manufacturingDate DateTime?
  expiryDate  DateTime?
  // ─── End inventory fields ───
  barcode     String?
  image       String?
  isActive    Boolean     @default(true)
  categoryId  String?
  category    Category?   @relation(fields: [categoryId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  variants    ProductVariant[]
}

// ─── Product Variants ────────────────────────────────────────────────────────
// A variant is a specific version of a product (e.g., different size, color, scent).
// Each variant has its own SKU, stock, and optionally its own price.
// If variant.price is null, the parent product's price is used.
// If variant.stock is 0, the parent product's stock is used.

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String   // e.g., "50ml - Pink", "Large - Gold"
  size      String?
  color     String?
  scent     String?
  sku       String   @unique  // auto-generated from product name + variant attrs
  price     Float?   // null = use parent product price
  stock     Int      @default(0)
  barcode   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orderItems OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  status        String      @default("COMPLETED") // COMPLETED, REFUNDED, PENDING
  // Payment: CASH = cash, MOMO = mobile money, CARD = bank card
  paymentMethod String      @default("CASH")
  // Ghana tax breakdown (all applied to taxableAmount)
  subtotal      Float       // basic amount (sum of line items before tax/discount)
  discount      Float       @default(0)
  taxableAmount Float       @default(0) // subtotal - discount
  nhil          Float       @default(0) // NHIL @ 2.5%
  getfund       Float       @default(0) // GETFund @ 2.5%
  vat           Float       @default(0) // VAT @ 10%
  tax           Float       @default(0) // total tax (nhil + getfund + vat) — kept for backward compat
  total         Float       // grand total (taxableAmount + tax)
  // Cash payment details
  amountTendered Float      @default(0) // cash amount given by customer
  changeGiven    Float      @default(0) // change returned to customer
  itemsCount    Int
  customerName  String?
  cashierName   String?
  cashierId     String?
  cashier       User?       @relation("OrderCashier", fields: [cashierId], references: [id])
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  name      String
  price     Float
  quantity  Int
  subtotal  Float
  createdAt DateTime @default(now())
}
